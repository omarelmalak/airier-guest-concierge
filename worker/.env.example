# RabbitMQ (Celery broker).
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# Twilio credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Postgres connection string (Supabase/DB) used to poll auto_messages.
DATABASE_URL=

# Gemini (guest SMS replies)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Flask internal server (Rails POSTs here). Optional; default port 5000.
# WORKER_API_URL in Rails must match (e.g. http://localhost:5000)
# PORT=5000
