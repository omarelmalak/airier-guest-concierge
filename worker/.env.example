# RabbitMQ (Celery broker).
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# Twilio credentials.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Postgres connection string (Supabase/DB) used to poll auto_messages.
DATABASE_URL=

# Cohere (embed guest SMS for exact-answer retrieval)
COHERE_API_KEY=

# Google Cloud Translation API v2 (detect + translate exact-answer replies)
# Enable "Cloud Translation API" in GCP and create an API key.
GOOGLE_TRANSLATE_API_KEY=
# GOOGLE_TRANSLATE_MIN_DETECT_CONFIDENCE=0.5

# Gemini (guest SMS replies)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Flask internal server (Rails POSTs here). Optional; default port 5000.
# WORKER_API_URL in Rails must match (e.g. http://localhost:5000)
# PORT=5000
